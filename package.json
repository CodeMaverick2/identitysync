{
  "name": "identity-sync",
  "type": "module",
  "version": "1.0.0",
  "description": "Bitespeed Identity Reconciliation - Link customer identities across purchases",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "db:migrate": "tsx src/db/migrate-cli.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "identity",
    "reconciliation",
    "bitespeed",
    "contacts"
  ],
  "author": "Tejas Ghatule",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "pg": "^8.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
